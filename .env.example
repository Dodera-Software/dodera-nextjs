# Slack — incoming webhook for the #leads channel
SLACK_LEADS_WEBHOOK_URL=

# Zoho SMTP (outgoing email)
ZOHO_SMTP_PASSWORD=

# ADMIN JWT secret (server-only — no NEXT_PUBLIC_ prefix)
