## DODERA TEST API KEY -- dod_dw-p4LoB0e3cbE-IC7cE3ONlawwlp5x_HpihVVra2UtW2BZRuZh92Z67gXFZxdxU

SITE_URL=https://doderasoft.com

# Supabase (server-only — no NEXT_PUBLIC_ prefix)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Prismic CMS (server-only — no NEXT_PUBLIC_ prefix)
PRISMIC_REPOSITORY_NAME=dodera-nextjs
PRISMIC_ACCESS_TOKEN=
PRISMIC_WRITE_TOKEN=

# Dev only — bypass SSL cert issues on Windows (remove in production)
NODE_TLS_REJECT_UNAUTHORIZED=0

# OpenAI (server-only — no NEXT_PUBLIC_ prefix)
OPENAI_API_KEY=
# DEPLOY_PLATFORM controls platform-specific behavior ("netlify" | "vercel")
DEPLOY_PLATFORM=netlify
# DEPLOY_PLATFORM is also exposed to the browser so the dashboard can switch links
NEXT_PUBLIC_DEPLOY_PLATFORM=netlify

# Netlify: CRON_SECRET — set this same value in Netlify dashboard → Environment variables -> Same as AUTO_POST_API_KEY for example
# (Vercel auto-injects CRON_SECRET; for Netlify you must set it manually)
CRON_SECRET=

# Admin quick-links (shown on dashboard — NEXT_PUBLIC so they reach the browser)
# -- Vercel --
NEXT_PUBLIC_ADMIN_LINK_VERCEL=https://vercel.com/denisdobra10s-projects/dodera-nextjs
NEXT_PUBLIC_ADMIN_LINK_VERCEL_ANALYTICS=https://vercel.com/denisdobra10s-projects/dodera-nextjs/analytics?environment=all
# -- Netlify --
NEXT_PUBLIC_ADMIN_LINK_NETLIFY=https://app.netlify.com/projects/dodera/overview
NEXT_PUBLIC_ADMIN_LINK_NETLIFY_ANALYTICS=https://app.netlify.com/projects/dodera/logs-and-metrics/analytics
# -- Shared --
NEXT_PUBLIC_ADMIN_LINK_PRISMIC_MIGRATION=https://dodera-nextjs.prismic.io/builder/migration
NEXT_PUBLIC_ADMIN_LINK_SUPABASE=https://supabase.com/dashboard/project/dvtbkseulufglvfdnehw

